generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Branch {
  id        Int      @id @default(autoincrement())
  name      String
  address   String?
  phone     String?
  users     User[]
  inventory Inventory[]
  sales     Sale[]
  purchases Purchase[]
  syncLogs  SyncLog[]
}

model User {
  id           Int      @id @default(autoincrement())
  branchId     Int
  name         String
  email        String   @unique
  passwordHash String
  role         String   // ADMIN | CAJERO | BODEGA
  branch       Branch   @relation(fields: [branchId], references: [id])
  sales        Sale[]
}

model Product {
  id         Int         @id @default(autoincrement())
  name       String
  barcode    String?     @unique
  categoryId Int?
  price      Float
  unitType   String      // UNIT | BOX | WEIGHT
  inventory  Inventory[]
  saleItems  SaleItem[]
  purchItems PurchaseItem[]
}

model Inventory {
  id        Int     @id @default(autoincrement())
  productId Int
  branchId  Int
  stock     Float
  minStock  Float
  product   Product @relation(fields: [productId], references: [id])
  branch    Branch  @relation(fields: [branchId], references: [id])

  @@unique([productId, branchId])
}

model Sale {
  id        Int        @id @default(autoincrement())
  branchId  Int
  userId    Int
  total     Float
  dteJson   String?
  createdAt DateTime   @default(now())
  branch    Branch     @relation(fields: [branchId], references: [id])
  user      User       @relation(fields: [userId], references: [id])
  items     SaleItem[]
}

model SaleItem {
  id        Int     @id @default(autoincrement())
  saleId    Int
  productId Int
  qty       Float
  price     Float
  sale      Sale    @relation(fields: [saleId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model Provider {
  id        Int        @id @default(autoincrement())
  name      String
  contact   String?
  email     String?
  purchases Purchase[]
}

model Purchase {
  id         Int            @id @default(autoincrement())
  branchId   Int
  providerId Int
  total      Float
  createdAt  DateTime       @default(now())
  branch     Branch         @relation(fields: [branchId], references: [id])
  provider   Provider       @relation(fields: [providerId], references: [id])
  items      PurchaseItem[]
}

model PurchaseItem {
  id         Int      @id @default(autoincrement())
  purchaseId Int
  productId  Int
  qty        Float
  cost       Float
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])
}

model SyncLog {
  id        Int      @id @default(autoincrement())
  branchId  Int
  tableName String
  operation String   // INSERT | UPDATE | DELETE
  recordId  Int
  status    String   // PENDING | SYNCED | ERROR
  createdAt DateTime @default(now())
  syncedAt  DateTime?
  branch    Branch   @relation(fields: [branchId], references: [id])
}
